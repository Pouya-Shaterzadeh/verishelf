# Verishelf uses bring-your-own-key: each visitor enters their own OpenAI API key
# in the app at runtime, so there is NO server-side API key to configure here.
# This file only holds optional overrides for local development.

# Default LLM model (users can also pick one in the UI). Any OpenAI chat model works.
# OPENAI_MODEL=gpt-4o-mini

# Point at an OpenAI-compatible endpoint instead of OpenAI (advanced).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Set to true to enable OCR for scanned PDFs (slower, much more memory).
# ENABLE_OCR=false
