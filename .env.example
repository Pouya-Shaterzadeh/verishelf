# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional overrides - defaults live in config/settings.py.
# Free models rotate; check https://openrouter.ai/models?max_price=0 if one 404s.
# Avoid "reasoning" models here (nvidia/nemotron-*:free, openai/gpt-oss-*:free) -
# they spend the token budget on hidden thinking and return an empty answer.
# RESEARCH_MODEL=google/gemma-4-26b-a4b-it:free
# VERIFICATION_MODEL=google/gemma-4-26b-a4b-it:free
# RELEVANCE_MODEL=google/gemma-4-26b-a4b-it:free

# Set to true to enable OCR for scanned PDFs (slower, much more memory)
# ENABLE_OCR=false
