# Get a free key at https://build.nvidia.com (NVIDIA Developer account, no card)
LLM_API_KEY=your-nvidia-api-key-here

# Optional overrides - defaults live in config/settings.py.
# Any OpenAI-compatible endpoint works (NVIDIA NIM by default). To use a different
# provider, set LLM_BASE_URL and pick model IDs that provider hosts.
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Avoid "reasoning" models - they spend the token budget on hidden thinking and
# return an empty answer on the small max_tokens these prompts use.
# RESEARCH_MODEL=meta/llama-3.1-8b-instruct
# VERIFICATION_MODEL=meta/llama-3.1-8b-instruct
# RELEVANCE_MODEL=meta/llama-3.1-8b-instruct

# Set to true to enable OCR for scanned PDFs (slower, much more memory)
# ENABLE_OCR=false
