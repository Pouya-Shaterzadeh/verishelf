# --- LLM providers (multi-provider failover) ---
# Each LLM call is tried against the providers in order until one succeeds, so a rate
# limit / outage on one silently falls over to the next. Set at least ONE key; set all
# three for full resilience. All free, no credit card.
NVIDIA_API_KEY=your-nvidia-api-key-here       # https://build.nvidia.com
GROQ_API_KEY=your-groq-api-key-here           # https://console.groq.com
OPENROUTER_API_KEY=your-openrouter-api-key    # https://openrouter.ai/keys

# Optional overrides - defaults live in config/settings.py.
# Failover order (only providers whose key is set are used):
# PROVIDER_ORDER=["nvidia", "groq", "openrouter"]
# Per-provider model IDs (each provider names the same model differently). Avoid
# "reasoning" models - they spend the token budget on hidden thinking and return an
# empty answer on the small max_tokens these prompts use.
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# GROQ_MODEL=llama-3.1-8b-instant
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Set to true to enable OCR for scanned PDFs (slower, much more memory)
# ENABLE_OCR=false
