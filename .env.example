# --- LLM providers (multi-provider failover) ---
# Each LLM call is tried against the providers in order until one succeeds, so a rate
# limit / outage on one silently falls over to the next. Set at least ONE key; set more
# for greater resilience. All free, no credit card.
CEREBRAS_API_KEY=your-cerebras-api-key     # https://cloud.cerebras.ai    (1M tokens/day; model lineup varies - see GET /v1/models)
NVIDIA_API_KEY=your-nvidia-api-key         # https://build.nvidia.com     (no daily cap)
GROQ_API_KEY=your-groq-api-key             # https://console.groq.com
OPENROUTER_API_KEY=your-openrouter-api-key # https://openrouter.ai/keys   (50/day)

# Google Gemini (~60 req/min) is supported but OFF by default - its free tier is
# limit:0 in many regions. If yours has it, set the key below AND add "gemini" to
# PROVIDER_ORDER (see config/settings.py or the override line below).
# GEMINI_API_KEY=your-gemini-api-key       # https://aistudio.google.com

# Optional overrides - defaults live in config/settings.py.
# Failover order (only providers whose key is set are used):
# PROVIDER_ORDER=["cerebras", "nvidia", "groq", "openrouter"]
# Per-provider model IDs (each provider names the same model differently). Avoid
# "reasoning" models - they burn the token budget on hidden thinking and return empty.
# CEREBRAS_MODEL=gemma-4-31b
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# GROQ_MODEL=llama-3.1-8b-instant
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Set to true to enable OCR for scanned PDFs (slower, much more memory)
# ENABLE_OCR=false
